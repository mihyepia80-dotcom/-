# Firebase 웹 앱 설정 (Firebase Console → 프로젝트 설정 → 일반 → 내 앱)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# Firestore 컬렉션 접두사 (학교·학기별 분리용, 예: midterm2026)
FIREBASE_COLLECTION_PREFIX=midterm2026

# 관리자 마스터 시트 동기화용 비밀키 (Vercel API / 선택)
# Firebase Console에서 발급한 값을 팀 내부에서만 공유
ADMIN_SYNC_KEY=

# Vercel 서버 API 전용 (js/env.js에 포함되지 않음 — Git 제외)
# 관리자 암호 (기본 260026, 서버에서만 검증)
ADMIN_PASSWORD=260026

# Gemini API (담당자 제출물 AI 분석 — Vercel 서버 전용)
GEMINI_API_KEY=

# Firebase Admin SDK JSON 한 줄 (Vercel 서버 전용)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}
