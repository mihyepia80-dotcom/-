# 환경변수는 Vercel 프로젝트 → Settings → Environment Variables 에서 설정합니다.
# 로컬 개발 시에만 .env.local 사용 (Git 제외). 배포는 Vercel 환경변수만 사용합니다.

# ── 클라이언트 (빌드 시 js/env.js 생성 — Vercel Build에 노출) ──
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_COLLECTION_PREFIX=midterm2026
ADMIN_SYNC_KEY=

# ── 서버 전용 (Vercel Runtime — js/env.js에 포함되지 않음) ──
ADMIN_PASSWORD=260026
GEMINI_API_KEY=

# Firebase Admin SDK JSON 한 줄 (Vercel 서버 API용, 필수)
# Firebase Console → 서비스 계정 → 새 비공개 키 → JSON 전체를 한 줄로
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}

# 로컬 개발만: firebase-service-account.json 파일을 프로젝트 루트에 두어도 됨 (Git 제외)
